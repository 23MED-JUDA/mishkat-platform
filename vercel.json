{
  "version": 2,
  "framework": null,
  "functions": {
    "api/**/*.php": { "runtime": "vercel-php@0.7.2" },
    "*.php": { "runtime": "vercel-php@0.7.2" },
    "pages/**/*.php": { "runtime": "vercel-php@0.7.2" },
    "includes/**/*.php": { "runtime": "vercel-php@0.7.2" }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/$", "dest": "/index.php" },
    { "src": "/login", "dest": "/login.php" },
    { "src": "/register", "dest": "/register.php" },
    { "src": "/dashboard", "dest": "/dashboard.php" },
    { "src": "/logout", "dest": "/logout.php" },
    { "src": "/(.*)\\.php$", "dest": "/$1.php" },
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}
